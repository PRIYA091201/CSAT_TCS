# ============================================================
# CSat / The Chennai Silks — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ============================================================

# ── Supabase (all apps share these) ──────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Kiosk app only (.env in apps/kiosk/) ─────────────────────
# Set by IT at tablet setup time. Never shared with admin/MD.
VITE_KIOSK_EMAIL=kiosk-browse@chennaisilks.local
VITE_KIOSK_PASSWORD=your-kiosk-password-here
